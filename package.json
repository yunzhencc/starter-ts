{
  "name": "pkg-name",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.1.3",
  "description": "_description_",
  "author": "wangxingkang <wang_xingkang@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yunzhencc/starter-ts.git"
  },
  "bugs": "https://github.com/yunzhencc/starter-ts/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "start": "tsx src/index.ts",
    "build": "tsdown",
    "test": "pnpm run build && vitest",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint:package": "publint",
    "typecheck": "tsc",
    "update-snapshot": "tsnapi -u -o test/__snapshots__/tsnapi/pkg-name",
    "prepare": "simple-git-hooks",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "es-toolkit": "catalog:core"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@commitlint/cli": "catalog:cli",
    "@commitlint/config-conventional": "catalog:cli",
    "@commitlint/types": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "publint": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsdown-stale-guard": "catalog:cli",
    "tsnapi": "catalog:cli",
    "tsx": "catalog:cli",
    "unrun": "catalog:cli",
    "vitest": "catalog:test"
  },
  "simple-git-hooks": {
    "commit-msg": "npx --no -- commitlint --edit $1",
    "pre-commit": "npx lint-staged",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
